    <content type="html"><![CDATA[<p>安装python3.6<br>pip3 install wheel –target=/usr/lib/python3.6/site-packages<br>pip3 install pyshark –target=/usr/lib/python3.6/site-packages</p><h4 id="导入pyshark报错"><a href="#导入pyshark报错" class="headerlink" title="导入pyshark报错"></a>导入pyshark报错</h4><figure class="highlight plain"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br></pre></td><td class="code"><pre><span class="line">Traceback (most recent call last):</span><br><span class="line">  File &quot;&lt;stdin&gt;&quot;, line 1, in &lt;module&gt;</span><br><span class="line">  File &quot;&#x2F;usr&#x2F;lib&#x2F;python3.6&#x2F;site-packages&#x2F;pyshark&#x2F;__init__.py&quot;, line 13, in &lt;module&gt;</span><br><span class="line">    from pyshark.capture.live_capture import LiveCapture</span><br><span class="line">  File &quot;&#x2F;usr&#x2F;lib&#x2F;python3.6&#x2F;site-packages&#x2F;pyshark&#x2F;capture&#x2F;live_capture.py&quot;, line 6, in &lt;module&gt;</span><br><span class="line">    from pyshark.capture.capture import Capture</span><br><span class="line">  File &quot;&#x2F;usr&#x2F;lib&#x2F;python3.6&#x2F;site-packages&#x2F;pyshark&#x2F;capture&#x2F;capture.py&quot;, line 13, in &lt;module&gt;</span><br><span class="line">    from pyshark.tshark.tshark_xml import packet_from_xml_packet, psml_structure_from_xml</span><br><span class="line">  File &quot;&#x2F;usr&#x2F;lib&#x2F;python3.6&#x2F;site-packages&#x2F;pyshark&#x2F;tshark&#x2F;tshark_xml.py&quot;, line 2, in &lt;module&gt;</span><br><span class="line">    import lxml.objectify</span><br><span class="line">ModuleNotFoundError: No module named &#39;lxml&#39;</span><br></pre></td></tr></table></figure><p>pip3 install lxml –target=/usr/lib/python3.6/site-packages</p>]]></content>
    
    
      
      
    <summary type="html">&lt;p&gt;安装python3.6&lt;br&gt;pip3 install wheel –target=/usr/lib/python3.6/site-packages&lt;br&gt;pip3 install pyshark –target=/usr/lib/python3.6/site-packag</summary>
      
    
    
    
